<title>GalateIA – Automatiza tu clínica con IA</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=Roboto+Mono:wght@400;500&display=swap');
  /* ─── TOKENS ─────────────────────────────────────────────── */
  :root {
    --cyan:    #00fbfb;
    --dark:    #1a1a1d;
    --white:   #ffffff;
    --grey:    #3a3a3d;
    --grey-lt: #5a5a60;
    --font-body: 'Inter', sans-serif;
    --font-head: 'Space Grotesk', sans-serif;
    --font-mono: 'Roboto Mono', monospace;
    --radius: 16px;
    --tr: .35s cubic-bezier(.4,0,.2,1);
  }

  /* ─── RESET ──────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--dark);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }
  img { max-width: 100%; display: block; }
  a { text-decoration: none; color: inherit; }

  /* ─── UTILITIES ──────────────────────────────────────────── */
  .container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }
  .cyan { color: var(--cyan); }
  .tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: .7rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--cyan);
    border: 1px solid rgba(0,251,251,.3);
    border-radius: 999px;
    padding: 4px 14px;
    margin-bottom: 20px;
  }
  .section { padding: 100px 0; }
  .section-title {
    font-family: var(--font-head);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 16px;
  }
  .section-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,.65);
    max-width: 560px;
    margin-bottom: 56px;
  }

  /* ─── BUTTONS ────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 1rem;
    border-radius: 999px;
    padding: 16px 36px;
    cursor: pointer;
    transition: transform var(--tr), box-shadow var(--tr), background var(--tr);
    border: none;
  }
  .btn-primary {
    background: var(--cyan);
    color: var(--dark);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 32px rgba(0,251,251,.45);
  }
  .btn-outline {
    background: transparent;
    color: var(--cyan);
    border: 1.5px solid var(--cyan);
  }
  .btn-outline:hover {
    background: rgba(0,251,251,.08);
    transform: translateY(-2px);
  }

  /* ─── NOISE OVERLAY ──────────────────────────────────────── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    opacity: .028;
    pointer-events: none;
    z-index: 9999;
  }

  /* ─── LOGO STRIP ─────────────────────────────────────────── */
  .logo-strip {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: 64px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(26,26,29,.85);
    border-bottom: 1px solid rgba(0,251,251,.1);
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }
  .logo-strip img {
    height: 52px;
    width: auto;
    object-fit: contain;
    object-position: center;
    /* fade out left and right edges so it blends seamlessly */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 12%,
      black 88%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 12%,
      black 88%,
      transparent 100%
    );
  }

  /* ─── HERO ───────────────────────────────────────────────── */
  #hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    padding: 120px 0 80px;
    overflow: hidden;
  }
  /* animated grid bg */
  #hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,251,251,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,251,251,.04) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: gridShift 20s linear infinite;
    pointer-events: none;
  }
  @keyframes gridShift {
    from { background-position: 0 0; }
    to   { background-position: 60px 60px; }
  }
  /* glow orb */
  #hero::after {
    content: '';
    position: absolute;
    top: 10%; left: 55%;
    width: 560px; height: 560px;
    background: radial-gradient(circle, rgba(0,251,251,.12) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    animation: pulse 6s ease-in-out infinite;
  }
  @keyframes pulse {
    0%,100% { transform: scale(1); opacity: 1; }
    50%      { transform: scale(1.08); opacity: .7; }
  }

  /* two-column grid — text left, dashboard right */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 48px;
    align-items: center;
    position: relative;
    z-index: 1;
    width: 100%;
  }
  .hero-content { min-width: 0; }
  .hero-headline {
    font-family: var(--font-head);
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -.03em;
    margin-bottom: 24px;
  }
  .hero-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,.7);
    margin-bottom: 36px;
    line-height: 1.7;
  }
  .hero-bullets {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 40px;
  }
  .hero-bullets span {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: .82rem;
    font-family: var(--font-mono);
    background: rgba(0,251,251,.07);
    border: 1px solid rgba(0,251,251,.2);
    border-radius: 999px;
    padding: 7px 14px;
    color: rgba(255,255,255,.85);
  }
  .hero-bullets span::before {
    content: '✔';
    color: var(--cyan);
    font-size: .72rem;
  }
  .hero-ctas { display: flex; align-items: flex-start; gap: 16px; flex-wrap: wrap; }

  /* dashboard mockup — now a normal grid column */
  .hero-visual {
    width: 100%;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(0,251,251,.15);
    border-radius: 20px;
    padding: 24px;
    backdrop-filter: blur(8px);
    animation: float 5s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes float {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-12px); }
  }
  .dash-bar {
    height: 8px;
    border-radius: 999px;
    background: rgba(255,255,255,.08);
    margin-bottom: 14px;
    overflow: hidden;
    position: relative;
  }
  .dash-bar::after {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    background: linear-gradient(90deg, var(--cyan), rgba(0,251,251,.4));
    border-radius: 999px;
    animation: barGrow 3s ease-in-out infinite;
  }
  .dash-bar:nth-child(1)::after { width: 78%; }
  .dash-bar:nth-child(2)::after { width: 55%; animation-delay: .3s; }
  .dash-bar:nth-child(3)::after { width: 91%; animation-delay: .6s; }
  @keyframes barGrow {
    0%,100% { opacity: 1; }
    50%      { opacity: .5; }
  }
  .dash-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 18px;
    padding: 12px;
    background: rgba(0,251,251,.05);
    border-radius: 10px;
    font-size: .8rem;
    font-family: var(--font-mono);
    color: rgba(255,255,255,.7);
  }
  .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--cyan);
    animation: blink 1.6s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }
  .dash-label { font-family: var(--font-head); font-size: .75rem; color: var(--white); }
  .dash-metric { margin-left: auto; color: var(--cyan); font-weight: 600; }

  /* ─── DOLOR ──────────────────────────────────────────────── */
  #dolor { background: rgba(255,255,255,.02); }
  .dolor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-bottom: 48px;
  }
  .dolor-card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: var(--radius);
    padding: 28px 24px;
    transition: border-color var(--tr), transform var(--tr);
  }
  .dolor-card:hover {
    border-color: rgba(0,251,251,.35);
    transform: translateY(-4px);
  }
  .dolor-icon { font-size: 1.6rem; margin-bottom: 12px; }
  .dolor-card p { font-size: .95rem; color: rgba(255,255,255,.7); }
  .impacto-box {
    background: linear-gradient(135deg, rgba(0,251,251,.08), rgba(0,251,251,.03));
    border: 1px solid rgba(0,251,251,.25);
    border-radius: var(--radius);
    padding: 36px 40px;
    text-align: center;
    font-family: var(--font-head);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 600;
    color: var(--white);
    max-width: 760px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* ─── SOLUCIÓN ───────────────────────────────────────────── */
  .pilares { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
  .pilar {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: var(--radius);
    padding: 36px 28px;
    position: relative;
    overflow: hidden;
    transition: border-color var(--tr), transform var(--tr);
  }
  .pilar::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--cyan), transparent);
    opacity: 0;
    transition: opacity var(--tr);
  }
  .pilar:hover::before { opacity: 1; }
  .pilar:hover { border-color: rgba(0,251,251,.3); transform: translateY(-6px); }
  .pilar-icon { font-size: 2.2rem; margin-bottom: 20px; }
  .pilar h3 {
    font-family: var(--font-head);
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .pilar p { font-size: .95rem; color: rgba(255,255,255,.65); }

  /* ─── AUTOMATIZAMOS ──────────────────────────────────────── */
  #automatizamos { background: rgba(255,255,255,.02); }
  .auto-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 14px;
    margin-bottom: 48px;
  }
  .auto-item {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(0,251,251,.05);
    border: 1px solid rgba(0,251,251,.12);
    border-radius: 10px;
    padding: 14px 16px;
    font-size: .88rem;
    font-family: var(--font-mono);
    color: rgba(255,255,255,.8);
    transition: background var(--tr), border-color var(--tr);
  }
  .auto-item:hover { background: rgba(0,251,251,.1); border-color: rgba(0,251,251,.3); }
  .auto-item::before { content: '✔'; color: var(--cyan); font-size: .75rem; flex-shrink: 0; }
  .auto-phrase {
    font-family: var(--font-head);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    text-align: center;
    color: var(--cyan);
    margin-top: 16px;
  }

  /* ─── DIFERENCIADOR ──────────────────────────────────────── */
  #diferenciador {
    position: relative;
    overflow: hidden;
  }
  #diferenciador::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(0,251,251,.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .dif-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .dif-text .section-title { font-size: clamp(1.8rem, 3vw, 2.6rem); }
  .dif-text p {
    font-size: 1rem;
    color: rgba(255,255,255,.65);
    margin-bottom: 32px;
    line-height: 1.8;
  }
  .dif-benefits { display: flex; flex-direction: column; gap: 14px; }
  .dif-benefit {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-head);
    font-size: .95rem;
    font-weight: 500;
  }
  .dif-benefit .check {
    width: 28px !important;
    height: 28px !important;
    background: rgba(0,251,251,.18) !important;
    border: 1.5px solid rgba(0,251,251,.6) !important;
    border-radius: 50% !important;
    display: grid !important;
    place-items: center !important;
    color: #00fbfb !important;
    font-size: .78rem !important;
    font-weight: 700 !important;
    flex-shrink: 0 !important;
    box-shadow: 0 0 8px rgba(0,251,251,.25) !important;
  }
  /* statue graphic */
  .statue-graphic {
    position: relative;
    height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
  }


  /* ─── ANTES / DESPUÉS ────────────────────────────────────── */
  #beneficios { background: rgba(255,255,255,.02); }
  .ad-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .ad-card {
    border-radius: var(--radius);
    padding: 40px 36px;
    border: 1px solid;
  }
  .ad-card.antes {
    background: rgba(255,60,60,.04);
    border-color: rgba(255,60,60,.15);
  }
  .ad-card.despues {
    background: rgba(0,251,251,.04);
    border-color: rgba(0,251,251,.2);
  }
  .ad-card h3 {
    font-family: var(--font-head);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 24px;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .antes h3 { color: rgba(255,100,100,.8); }
  .despues h3 { color: var(--cyan); }
  .ad-list { list-style: none; display: flex; flex-direction: column; gap: 14px; }
  .ad-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: .95rem;
